[Unit]
Description=Sing Grok Next.js frontend
After=network-online.target sing-grok-api.service
Wants=network-online.target

[Service]
Type=simple
User=sing-grok
Group=sing-grok
WorkingDirectory=/opt/sing-grok/frontend
EnvironmentFile=/etc/sing-grok/web.env
ExecStart=/usr/bin/env node /opt/sing-grok/frontend/.next/standalone/server.js
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/var/log/sing-grok

[Install]
WantedBy=multi-user.target
